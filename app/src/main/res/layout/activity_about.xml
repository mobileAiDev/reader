<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white">

        <ImageButton
            android:id="@+id/about_back"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:layout_gravity="left|center_vertical"
            android:background="@color/transparent"
            android:contentDescription="返回"
            android:padding="16dp"
            android:src="@drawable/ic_settings_back_32" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="56dp"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:text="关于本应用"
            android:textColor="#222222"
            android:textSize="18sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="12dp"
        android:background="@drawable/bg_mine_panel"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="28dp"
        android:paddingBottom="28dp">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_mine_avatar"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_app_logo" />

        <TextView
            android:id="@+id/about_app_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/app_name"
            android:textColor="@color/home_text_primary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/about_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="版本 1.0"
            android:textColor="@color/home_text_tertiary"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
