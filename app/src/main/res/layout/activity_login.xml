<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/login_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_background"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/iv_login_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_login_button_secondary"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_close_window" />

    <ScrollView
        android:id="@+id/login_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="24dp"
        android:paddingLeft="22dp"
        android:paddingRight="22dp"
        android:paddingTop="76dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/login_header_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="登录 Reader"
                android:textColor="@color/home_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/login_header_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:text="同步书架、阅读进度和最近章节"
                android:textColor="@color/home_text_secondary"
                android:textSize="14sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp">

                <LinearLayout
                    android:id="@+id/ll_user_not_login"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_login_panel"
                    android:orientation="vertical"
                    android:paddingBottom="28dp"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:paddingTop="24dp">

                    <TextView
                        android:id="@+id/login_form_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="手机号登录"
                        android:textColor="@color/home_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/login_form_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:text="使用验证码登录后自动同步当前书架"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:id="@+id/login_phone_row"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_login_input"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="13dp"
                        android:paddingRight="6dp">

                        <ImageView
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:src="@drawable/ic_login_phone_24" />

                        <EditText
                            android:id="@+id/et_user_phone"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="9dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="手机号码"
                            android:inputType="phone"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/home_text_primary"
                            android:textColorHint="@color/home_text_tertiary"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/btn_get_sms_code"
                            android:layout_width="100dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_login_button_secondary"
                            android:gravity="center"
                            android:stateListAnimator="@null"
                            android:text="获取验证码"
                            android:textAllCaps="false"
                            android:textColor="@color/home_primary_dark"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/login_code_row"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_login_input"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="13dp"
                        android:paddingRight="13dp">

                        <ImageView
                            android:layout_width="19dp"
                            android:layout_height="19dp"
                            android:src="@drawable/ic_login_code_24" />

                        <EditText
                            android:id="@+id/et_sms_code_input"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="9dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="验证码"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="@color/home_text_primary"
                            android:textColorHint="@color/home_text_tertiary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_user_login"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_login_button_primary"
                        android:stateListAnimator="@null"
                        android:text="验证码登录"
                        android:textAllCaps="false"
                        android:textColor="@color/home_text_on_primary"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/btn_direct_login"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_login_button_secondary"
                        android:gravity="center"
                        android:stateListAnimator="@null"
                        android:text="本机号码一键登录"
                        android:textAllCaps="false"
                        android:textColor="@color/home_primary_dark"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_user_login"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_login_panel"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingBottom="30dp"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:paddingTop="32dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ImageView
                        android:id="@+id/iv_user_logo"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:background="@drawable/bg_login_state_avatar"
                        android:padding="15dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_user_logo" />

                    <TextView
                        android:id="@+id/login_state_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:includeFontPadding="false"
                        android:text="已登录"
                        android:textColor="@color/home_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:includeFontPadding="false"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="14sp"
                        tools:text="reader_user" />

                    <TextView
                        android:id="@+id/login_state_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:text="书架和阅读进度会随账号同步"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_user_logout"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="28dp"
                        android:background="@drawable/bg_login_button_secondary"
                        android:stateListAnimator="@null"
                        android:text="退出登录"
                        android:textAllCaps="false"
                        android:textColor="@color/home_primary_dark"
                        android:textSize="16sp" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
