<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:orientation="vertical"
    android:paddingLeft="20dp"
    android:paddingRight="20dp"
    android:paddingTop="8dp">

    <LinearLayout
        android:id="@+id/home_shelf_summary"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/home_reading_time_chip"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_home_reading_chip"
            android:clickable="true"
            android:drawableRight="@drawable/ic_home_reading_arrow_18"
            android:drawablePadding="6dp"
            android:focusable="true"
            android:fontFamily="sans-serif"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:includeFontPadding="false"
            android:paddingLeft="14dp"
            android:paddingRight="12dp"
            android:text="本周读0分钟"
            android:textColor="@color/home_text_primary"
            android:textSize="14sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/home_bookshelf_tools"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/home_bookshelf_filter"
                android:layout_width="58dp"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif"
                android:text="筛选"
                android:textColor="@color/home_text_primary"
                android:textSize="14sp" />

            <View
                android:id="@+id/home_bookshelf_tool_divider"
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:background="@color/home_line" />

            <TextView
                android:id="@+id/home_bookshelf_source_engine"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:clickable="true"
                android:drawableLeft="@drawable/ic_home_source_engine_20"
                android:drawablePadding="4dp"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif"
                android:text="书源"
                android:textColor="@color/home_text_primary"
                android:textSize="14sp" />

            <View
                android:id="@+id/home_bookshelf_source_divider"
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:background="@color/home_line" />

            <TextView
                android:id="@+id/home_bookshelf_edit"
                android:layout_width="58dp"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif"
                android:text="编辑"
                android:textColor="@color/home_text_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/home_section_title"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center_vertical"
        android:includeFontPadding="false"
        android:text="我的书架"
        android:textColor="@color/home_text_primary"
        android:textSize="0sp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/home_bookshelf_content_frame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.ldp.reader.widget.refresh.ScrollRefreshRecyclerView
            android:id="@+id/book_shelf_rv_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scroll_empty="@layout/view_empty_book_shelf" />

        <LinearLayout
            android:id="@+id/home_bookshelf_filter_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingLeft="60dp"
            android:paddingRight="60dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/home_bookshelf_filter_empty_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="重拾阅读习惯，从添加一本书开始"
                android:textColor="@color/home_text_tertiary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/home_bookshelf_filter_empty_reset"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_bookshelf_filter_empty_primary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="全部书籍"
                android:textColor="@color/home_text_on_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/home_bookshelf_filter_empty_import"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_bookshelf_filter_empty_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="去导入"
                android:textColor="#1E86FF"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/home_bookshelf_edit_bar"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="@color/home_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/home_bookshelf_select_all"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:drawablePadding="4dp"
            android:drawableTop="@drawable/ic_bookshelf_select_all_24"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="全选"
            android:textColor="@color/home_text_primary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/home_bookshelf_delete_selected"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:drawablePadding="4dp"
            android:drawableTop="@drawable/ic_bookshelf_delete_24"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="删除"
            android:textColor="@color/home_primary"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
