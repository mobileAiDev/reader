<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    android:layout_marginLeft="0dp"
    android:layout_marginRight="0dp"
    android:layout_marginTop="6dp"
    android:background="@drawable/selector_home_book_card_long_press"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="132dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/coll_book_iv_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_home_book_cover"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_book_loading"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Reader.BookCover" />

        <FrameLayout
            android:id="@+id/coll_book_local_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_bookshelf_local_cover"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/coll_book_local_cover_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="14dp"
                android:layout_marginTop="18dp"
                android:layout_marginRight="12dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:lineSpacingExtra="2dp"
                android:maxLines="4"
                android:textColor="#737B77"
                android:textSize="16sp"
                tools:text="codex-local-import-probe" />

            <TextView
                android:id="@+id/coll_book_local_cover_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="18dp"
                android:includeFontPadding="false"
                android:textColor="#AEB5B0"
                android:textSize="16sp"
                tools:text="-TXT-" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="right|top"
                android:src="@drawable/ic_bookshelf_local_fold_40" />
        </FrameLayout>

        <ImageView
            android:id="@+id/coll_book_iv_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right|top"
            android:src="@drawable/label_book_top"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/coll_book_iv_red_rot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="right|top"
            android:layout_marginRight="5dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/notif_red_dot"
            android:visibility="gone"
            tools:visibility="visible" />

        <CheckBox
            android:id="@+id/coll_book_cb_selected"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="right|top"
            android:layout_marginRight="6dp"
            android:layout_marginTop="6dp"
            android:background="@android:color/transparent"
            android:button="@drawable/selector_bookshelf_edit_check"
            android:clickable="false"
            android:focusable="false"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:visibility="gone"
            tools:visibility="visible" />
    </FrameLayout>

    <TextView
        android:id="@+id/coll_book_tv_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:textColor="@color/home_text_primary"
        android:textSize="16sp"
        android:fontFamily="sans-serif"
        tools:text="逆鳞" />

    <TextView
        android:id="@+id/coll_book_tv_lately_update"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/home_text_secondary"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        tools:text="17小时前" />

    <TextView
        android:id="@+id/coll_book_tv_chapter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textColor="@color/home_text_secondary"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        tools:text="第二卷 逆水行舟" />
</LinearLayout>
